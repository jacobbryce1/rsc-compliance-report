# RSC Compliance Report — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.
# The .gitignore already excludes it.

# ── Required ────────────────────────────────────────────────────────────────

# Your RSC instance URL (no trailing slash)
# Example: https://your-org.my.rubrik.com
RSC_URL=

# Service Account credentials (created in RSC > Settings > Service Accounts)
# The service account needs at minimum: read-only access to AWS native objects,
# SLA domains, and snappable compliance data.
RSC_CLIENT_ID=
RSC_CLIENT_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────

# Custom CA bundle path for environments with corporate TLS inspection proxies.
# If unset, the system CA store is used (verify=True is always enforced).
# RSC_CA_BUNDLE=/path/to/custom-ca-bundle.crt
